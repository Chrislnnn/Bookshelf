WindowManager:
    HomeScreen:
    ShelfScreen:
    SearchScreen:
    StatisticsScreen:
    BookDetailScreen:
    ReadBookScreen:
    CurrentBookScreen:
    ToBeReadScreen:

<HomeScreen>:
    name: "home"

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 0.9

            BoxLayout:
                size_hint: 1, 0.1
                canvas.before:
                    Color:
                        rgba: 0.13, 0.13, 0.13, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: 1, 1
                    pos_hint: {'x': 1, 'center_y': 0.5}

                    Button:
                        text: 'Read ' + root.read_count
                        color: 1, 1, 1, 1
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        background_down: ''
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        font_size: '16sp'
                        size_hint: 1, 1
                        on_release:
                            self.background_color = 0.0, 0.0, 0.0, 0.0
                            app.root.current = "shelf"
                            root.manager.transition.direction = "left"
                            root.manager.get_screen('shelf').load_books('read')

                    Button:
                        text: 'Reading ' + root.reading_count + ''
                        color: 1, 1, 1, 1
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        background_down: ''
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        font_size: '16sp'
                        size_hint: 1, 1
                        on_release:
                            self.background_color = 0, 0, 0, 0
                            app.root.current = "shelf"
                            root.manager.transition.direction = "left"
                            root.manager.get_screen('shelf').load_books('reading')

                    Button:
                        text: 'TBR ' + root.future_count + ''
                        color: 1, 1, 1, 1
                        background_normal: ''
                        background_color: 0, 0, 0, 0
                        background_down: ''
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        font_size: '16sp'
                        size_hint: 1, 1
                        on_release:
                            self.background_color = 0, 0, 0, 0
                            app.root.current = "shelf"
                            root.manager.transition.direction = "left"
                            root.manager.get_screen('shelf').load_books('tbr')

            BoxLayout:
                size_hint: 1, 0.05

            ScrollView:
                size_hint: 1, 0.75
                GridLayout:
                    id: books_grid
                    cols: 1
                    size_hint_x: None
                    width: self.minimum_width
                    height: self.minimum_height

        BoxLayout:
            size_hint: 1, 0.1
            canvas.before:
                Color:
                    rgba: 0.13, 0.13, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            FloatLayout:

                MDIconButton:
                    icon: "home"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0, 'center_y': 0.5}
                    on_release:
                        app.root.current = "home"
                        root.manager.transition.direction = "left"


                MDIconButton:
                    icon: "bookshelf"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.25, 'center_y': 0.5}
                    on_release:
                        app.root.current = "shelf"
                        root.manager.transition.direction = "left"


                MDIconButton:
                    icon: "magnify"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.5, 'center_y': 0.5}
                    on_release:
                        app.root.current = "search"
                        root.manager.transition.direction = "left"


                MDIconButton:
                    icon: "chart-bar"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.75, 'center_y': 0.5}
                    on_release:
                        app.root.current = "statistics"
                        root.manager.transition.direction = "left"

<ShelfScreen>:
    name: "shelf"

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 0.9

            BoxLayout:
                size_hint: 1, 0.1
                canvas.before:
                    Color:
                        rgba: 0.13, 0.13, 0.13, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: 1, 1
                    pos_hint: {'x': 1, 'center_y': 0.5}

                    Button:
                        text: 'Read'
                        on_release:
                            root.load_books('read')
                            self.background_color = 0, 0, 0, 0
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        color: 1, 1, 1, 1
                        background_color: 0, 0, 0, 0
                        size_hint: 1, 1
                        font_size: '16sp'
                        background_normal: ''
                        background_down: ''
                    Button:
                        text: 'Reading'
                        on_release:
                            root.load_books('reading')
                            self.background_color = 0, 0, 0, 0
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        color: 1, 1, 1, 1
                        background_color: 0, 0, 0, 0
                        size_hint: 1, 1
                        font_size: '16sp'
                        background_normal: ''
                        background_down: ''
                    Button:
                        text: 'TBR'
                        on_release:
                            root.load_books('tbr')
                            self.background_color = 0, 0, 0, 0
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        color: 1, 1, 1, 1
                        background_color: 0, 0, 0, 0
                        size_hint: 1, 1
                        font_size: '16sp'
                        background_normal: ''
                        background_down: ''

            ScrollView:
                size_hint: 1, 0.9
                GridLayout:
                    id: books_grid
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height

        BoxLayout:
            size_hint: 1, 0.1
            canvas.before:
                Color:
                    rgba: 0.13, 0.13, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            FloatLayout:
                MDIconButton:
                    icon: "home"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0, 'center_y': 0.5}
                    on_release:
                        app.root.current = "home"
                        root.manager.transition.direction = "right"


                MDIconButton:
                    icon: "bookshelf"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.25, 'center_y': 0.5}
                    on_release:
                        app.root.current = "shelf"
                        root.manager.transition.direction = "left"


                MDIconButton:
                    icon: "magnify"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.5, 'center_y': 0.5}
                    on_release:
                        app.root.current = "search"
                        root.manager.transition.direction = "left"


                MDIconButton:
                    icon: "chart-bar"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.75, 'center_y': 0.5}
                    on_release:
                        app.root.current = "statistics"
                        root.manager.transition.direction = "left"


<SearchScreen>:
    name: "search"

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 0.9

            BoxLayout:
                size_hint: 1, 0.1
                canvas.before:
                    Color:
                        rgba: 0.13, 0.13, 0.13, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                BoxLayout:
                    BoxLayout:
                        padding: dp(10), 0, 0, 0
                        size_hint: 0.75, 1
                        TextInput:
                            id: search_input
                            pos_hint: {'x': 0, 'center_y': 0.5}
                            hint_text_color: 0, 0, 0, 0.5
                            foreground_color: 1, 1, 1, 1
                            background_color: 0, 0, 0, 0
                            hint_text: 'Buchtitel...'
                            hint_text_color: 1, 1, 1, 1
                            size_hint_y: None
                            font_size: '16sp'
                            height: self.parent.height
                            multiline: False
                            padding: [10, (self.height - self.line_height) / 2]

                    Button:
                        padding: 0, 0, 0, dp(10)
                        color: 1, 1, 1, 1
                        background_color: 0, 0, 0, 0
                        size_hint: 0.25, 1
                        pos_hint: {'x': 0, 'center_y': 0.5}
                        text: 'Suchen'
                        font_size: '16sp'
                        height: self.parent.height
                        on_release:
                            root.search_books(search_input.text)
                            self.background_color = 0, 0, 0, 0
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        background_normal: ''
                        background_down: ''


            ScrollView:
                size_hint: 1, 0.9
                GridLayout:
                    id: books_grid
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height

        BoxLayout:
            size_hint: 1, 0.1
            canvas.before:
                Color:
                    rgba: 0.13, 0.13, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            FloatLayout:

                MDIconButton:
                    icon: "home"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0, 'center_y': 0.5}
                    on_release:
                        app.root.current = "home"
                        root.manager.transition.direction = "right"


                MDIconButton:
                    icon: "bookshelf"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.25, 'center_y': 0.5}
                    on_release:
                        app.root.current = "shelf"
                        root.manager.transition.direction = "right"


                MDIconButton:
                    icon: "magnify"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.5, 'center_y': 0.5}
                    on_release:
                        app.root.current = "search"
                        root.manager.transition.direction = "left"


                MDIconButton:
                    icon: "chart-bar"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.75, 'center_y': 0.5}
                    on_release:
                        app.root.current = "statistics"
                        root.manager.transition.direction = "left"

<StatisticsScreen>:
    name: "statistics"

    BoxLayout:
        orientation: 'vertical'
        spacing: 0

        BoxLayout:
            orientation: 'vertical'
