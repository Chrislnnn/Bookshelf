            ScrollView:
                size_hint: 1, 1
                GridLayout:
                    id: graphs
                    spacing: dp(20)
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height

        BoxLayout:
            size_hint: 1, 0.1
            canvas.before:
                Color:
                    rgba: 0.13, 0.13, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            FloatLayout:

                MDIconButton:
                    icon: "home"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0, 'center_y': 0.5}
                    on_release:
                        app.root.current = "home"
                        root.manager.transition.direction = "right"


                MDIconButton:
                    icon: "bookshelf"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.25, 'center_y': 0.5}
                    on_release:
                        app.root.current = "shelf"
                        root.manager.transition.direction = "right"


                MDIconButton:
                    icon: "magnify"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.5, 'center_y': 0.5}
                    on_release:
                        app.root.current = "search"
                        root.manager.transition.direction = "right"


                MDIconButton:
                    icon: "chart-bar"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 0.25, 1
                    pos_hint: {'x': 0.75, 'center_y': 0.5}
                    on_release:
                        app.root.current = "statistics"
                        root.manager.transition.direction = "left"

<BookDetailScreen>:
    name: "book_detail"

    BoxLayout:
        orientation: 'vertical'
        spacing: 0
        id: box

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 0.9

            BoxLayout:
                size_hint: 1, 0.1
                canvas.before:
                    Color:
                        rgba: 0.13, 0.13, 0.13, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                Button:
                    color: 1, 1, 1, 1
                    background_color: 0, 0, 0, 0
                    text: 'Back'
                    font_size: '16sp'
                    size_hint: 1, 1
                    on_release:
                        root.manager.transition.direction = "right"
                        app.root.current = 'search'
                        self.background_color = 0, 0, 0, 0
                    on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                    background_normal: ''
                    background_down: ''

            ScrollView:
                BoxLayout:
                    size_hint: 1, 0.9
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 10
                    spacing: 10

                    AsyncImage:
                        id: book_cover
                        source: ''
                        size_hint: 1, None
                        width: box.width * 0.8
                        height: box.height * 0.8 * 0.6
                        keep_ratio: True
                        allow_stretch: True

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    Label:
                        id: book_title
                        text: ''
                        font_size: '20sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: book_authors
                        text: ''
                        font_size: '18sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: book_year
                        text: ''
                        font_size: '18sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]
                    Label:
                        id: book_genre
                        text: ''
                        font_size: '18sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]

                    Label:
                        id: book_publisher
                        text: ''
                        color: 0, 0, 0, 1
                        size_hint_y: 0
                        height: 0
                        opacity: 0

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    BoxLayout:
                        size_hint_y: None
                        height: 100
                        spacing: 0
                        orientation: 'horizontal'
                        Label:
                            text: 'Page count: '
                            size_hint_x: None
                            size_hint: 1, 1
                            font_size: '18sp'
                            color: 0, 0, 0, 1
                            size_hint_y: 1
                        Label:
                            id: book_page_count
                            text: ''
                            size_hint_x: None
                            size_hint: 1, 1
                            font_size: '18sp'
                            color: 0, 0, 0, 1
                            size_hint_y: 1

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size
                    Label:
                        id: book_maturity_rating
                        text: ''
                        color: 0, 0, 0, 1
                        size_hint_y: 0
                        height: 0
                        opacity: 0

                    Label:
                        id: book_description
                        text: ''
                        font_size: '16sp'
                        text_size: self.width, None
                        halign: 'left'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]
                        padding_x: 10


        BoxLayout:
            size_hint: 1, 0.1
            canvas.before:
                Color:
                    rgba: 0.13, 0.13, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                orientation: 'horizontal'
                size_hint: 1, 1
                pos_hint: {'x': 1, 'center_y': 0.5}

                Button:
                    text: 'Read'
                    color: 1, 1, 1, 1
                    background_color: 0, 0, 0, 0
                    on_release:
                        root.add_to_read()
                        self.background_color = 0, 0, 0, 0
                    size_hint: 1, 1
                    font_size: '16sp'
                    on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                    background_normal: ''
                    background_down: ''

                Button:
                    text: 'Currently \n reading'
                    color: 1, 1, 1, 1
                    background_color: 0, 0, 0, 0
                    on_release:
                        root.add_to_reading()
                        self.background_color = 0, 0, 0, 0
                    size_hint: 1, 1
                    font_size: '16sp'
                    on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                    background_normal: ''
                    background_down: ''

                Button:
                    text: 'To be \n read'
                    color: 1, 1, 1, 1
                    background_color: 0, 0, 0, 0
                    on_release:
                        root.add_to_future()
                        self.background_color = 0, 0, 0, 0
                    size_hint: 1, 1
                    font_size: '16sp'
                    on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                    background_normal: ''
                    background_down: ''


<ReadBookScreen>:
    name: "read_book"

    BoxLayout:
        orientation: 'vertical'
        spacing: 0
        id:box

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 0.9

            BoxLayout:
                size_hint: 1, 0.1
                canvas.before:
                    Color:
                        rgba: 0.13, 0.13, 0.13, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: 1, 1
                    pos_hint: {'x': 1, 'center_y': 0.5}

                    Button:
                        color: 1, 1, 1, 1
                        background_color: 0, 0, 0, 0
                        text: 'Back'
                        size_hint: 1, 1
                        font_size: '16sp'
                        on_release:
                            root.manager.transition.direction = "right"
                            root.manager.current = app.last_screen if app.last_screen else 'default_screen_fallback'
                            self.background_color = 0, 0, 0, 0
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        background_normal: ''
                        background_down: ''

            ScrollView:
                size_hint: 1, 0.9
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 10
                    spacing: 10

                    Label:
                        id: book_id
                        text: ''
                        font_size: '20sp'
                        size_hint_y: None
                        height: 0
                    AsyncImage:
                        id: book_cover
                        source: ''
                        size_hint: 1, None
                        width: box.width * 0.8
                        height: box.height * 0.8 * 0.6
                        keep_ratio: True
                        allow_stretch: True

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    Label:
                        id: book_title
                        text: ''
                        font_size: '20sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]
                    Label:
                        id: book_authors
                        text: ''
                        font_size: '18sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]
                    Label:
                        id: book_year
                        text: ''
                        font_size: '18sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]
                    Label:
                        id: book_genre
                        text: ''
                        font_size: '18sp'
                        text_size: self.width, None
                        halign: 'center'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    BoxLayout:
                        size_hint_y: None
                        height: 100
                        spacing: 0
                        orientation: 'horizontal'
                        Label:
                            text: 'Page count: '
                            size_hint_x: None
                            size_hint: 1, 1
                            font_size: '18sp'
                            color: 0, 0, 0, 1
                            size_hint_y: 1
                        Label:
                            id: book_page_count
                            text: ''
                            size_hint_x: None
                            size_hint: 1, 1
                            font_size: '18sp'
                            color: 0, 0, 0, 1
                            size_hint_y: 1

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    AnchorLayout:
                        size_hint_y: None
                        height: 50

                        BoxLayout:
                            orientation: 'horizontal'
                            spacing: 10
                            size_hint_x: None
                            width: min(root.width * 0.9, dp(300))

                            Button:
                                id: star1
                                background_normal: 'emptystar.png'
                                background_down: 'filledstar.png'
                                size_hint: 1, None
                                height: self.width
                                allow_stretch: True
                                keep_ratio: True
                                on_press: root.update_rating(1)

                            Button:
                                id: star2
                                background_normal: 'emptystar.png'
                                background_down: 'filledstar.png'
                                size_hint: 1, None
                                height: self.width
                                allow_stretch: True
                                keep_ratio: True
                                on_press: root.update_rating(2)

                            Button:
                                id: star3
                                background_normal: 'emptystar.png'
                                background_down: 'filledstar.png'
                                size_hint: 1, None
                                height: self.width
                                allow_stretch: True
                                keep_ratio: True
                                on_press: root.update_rating(3)

                            Button:
                                id: star4
                                background_normal: 'emptystar.png'
                                background_down: 'filledstar.png'
                                size_hint: 1, None
                                height: self.width
                                allow_stretch: True
                                keep_ratio: True
                                on_press: root.update_rating(4)

                            Button:
                                id: star5
                                background_normal: 'emptystar.png'
                                background_down: 'filledstar.png'
                                size_hint: 1, None
                                height: self.width
                                allow_stretch: True
                                keep_ratio: True
                                on_press: root.update_rating(5)

                    Widget:
                        size_hint_y: None
                        height: 1
                        canvas.before:
                            Color:
                                rgba: 0, 0, 0, 1
                            Rectangle:
                                pos: self.pos
                                size: self.size

                    Label:
                        id: book_description
                        text: ''
                        font_size: '16sp'
                        text_size: self.width, None
                        halign: 'left'
                        valign: 'middle'
                        color: 0, 0, 0, 1
                        size_hint_y: None
                        height: self.texture_size[1]
                        padding_x: 10

                    Label:
                        id: book_publisher
                        text: ''
                        color: 0, 0, 0, 1
                        size_hint_y: 0
                        height: 0
                        opacity: 0

                    Label:
                        id: book_maturity_rating
                        text: ''
                        color: 0, 0, 0, 1
                        size_hint_y: 0
                        height: 0
                        opacity: 0


                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_y: None
                        height: 100

                        AnchorLayout:
                            anchor_x: 'center'
                            anchor_y: 'center'

                            MDTextField:
                                id: field
                                mode: "outlined"
                                size_hint_x: 1
                                height: 56
                                on_focus: root.show_date_picker(self.focus)

                                MDTextFieldHintText:
                                    id: MD_text
                                    text: "Finished on:"

                                MDTextFieldHelperText:
                                    text: "MM/DD/YYYY"
                                    mode: "persistent"

                                MDTextFieldTrailingIcon:
                                    icon: "calendar"

        BoxLayout:
            size_hint: 1, 0.1
            canvas.before:
                Color:
                    rgba: 0.13, 0.13, 0.13, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BoxLayout:
                orientation: 'horizontal'
                size_hint: 1, 1
                pos_hint: {'x': 1, 'center_y': 0.5}

                MDIconButton:
                    icon: "delete"
                    theme_icon_color: "Custom"
                    icon_color: 1, 1, 1, 1
                    keep_ratio: True
                    allow_stretch: True
                    size_hint: 1, 1
                    pos_hint: {'x': 0, 'center_y': 0.5}
                    on_release: root.delete_book()

                Button:
                    text: 'Reading'
                    size_hint: 1, 1
                    pos_hint: {'x': 0.25, 'center_y': 0.5}
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    font_size: '16sp'
                    on_release:
                        root.move_to_reading()
                        self.background_color = 0, 0, 0, 0
                    on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                    background_normal: ''
                    background_down: ''

                Button:
                    text: 'TBR'
                    size_hint: 1, 1
                    pos_hint: {'x': 0.5, 'center_y': 0.5}
                    background_color: 0, 0, 0, 0
                    color: 1, 1, 1, 1
                    font_size: '16sp'
                    on_release:
                        root.move_to_tbr()
                        self.background_color = 0, 0, 0, 0
                    on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                    background_normal: ''
                    background_down: ''

<CurrentBookScreen>:
    name: 'current_book'

    BoxLayout:
        orientation: 'vertical'
        spacing: 0
        id:box

        BoxLayout:
            orientation: 'vertical'
            size_hint: 1, 0.9

            BoxLayout:
                size_hint: 1, 0.1
                canvas.before:
                    Color:
                        rgba: 0.13, 0.13, 0.13, 1
                    Rectangle:
                        pos: self.pos
                        size: self.size

                BoxLayout:
                    orientation: 'horizontal'
                    size_hint: 1, 1
                    pos_hint: {'x': 1, 'center_y': 0.5}

                    Button:
                        color: 1, 1, 1, 1
                        background_color: 0, 0, 0, 0
                        text: 'Back'
                        size_hint: 1, 1
                        font_size: '16sp'
                        on_release:
                            root.manager.transition.direction = "right"
                            root.manager.current = app.last_screen if app.last_screen else 'default_screen_fallback'
                            self.background_color = 0, 0, 0, 0
                        on_press: self.background_color = 0.7, 0.7, 0.7, 0.25
                        background_normal: ''
                        background_down: ''

